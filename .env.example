# OpenRouter Configuration
# Get your API key from https://openrouter.ai/keys
OR_API_KEY=your_openrouter_api_key_here

# Optional: Use different OpenRouter model
# OR_MODEL=meta-llama/llama-2-70b
# OR_MODEL=openrouter/auto

# Optional: Use custom OpenRouter base URL
# OR_BASE=https://openrouter.ai/api/v1

# MongoDB Configuration (already set in docker-compose.yml)
# MONGO_URI=mongodb://admin:secret123@mongodb:27017/codelens?authSource=admin

# Redis Configuration (already set in docker-compose.yml)
# REDIS_URL=redis://:redis123@redis:6379

# JWT Secret for authentication
# JWT_SECRET=your_jwt_secret_key_here

# Frontend API URL
# REACT_APP_API_URL=http://localhost:5000
